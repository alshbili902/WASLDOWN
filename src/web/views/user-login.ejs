<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>تسجيل الدخول - وصل داونلودر</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    body { font-family: 'Tajawal', sans-serif; background-color: #0f172a; color: #f8fafc; }
  </style>
</head>
<body class="min-h-screen flex items-center justify-center">

  <div class="bg-slate-800 p-8 md:p-12 rounded-3xl shadow-2xl border border-slate-700 w-full max-w-md relative overflow-hidden">
    <!-- Glow Effect -->
    <div class="absolute -top-10 -left-10 w-40 h-40 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
    <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-purple-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>

    <div class="relative z-10 text-center mb-10">
      <h1 class="text-3xl font-black text-white flex justify-center items-center gap-3 mb-2">
        تسجيل الدخول <i data-lucide="log-in" class="text-blue-400"></i>
      </h1>
      <p class="text-slate-400">مرحباً بعودتك إلى منصة وصل داونلودر</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-500/10 border border-red-500/50 text-red-400 p-4 rounded-xl mb-6 text-sm font-bold text-center">
        <%= error %>
      </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="bg-emerald-500/10 border border-emerald-500/50 text-emerald-400 p-4 rounded-xl mb-6 text-sm font-bold text-center">
        <%= success %>
      </div>
    <% } %>

    <form action="/login" method="POST" class="space-y-6">
      <input type="hidden" name="redirect" value="<%= locals.redirect || '' %>">

      <div>
        <label class="block text-slate-400 text-sm font-bold mb-2">البريد الإلكتروني</label>
        <div class="relative">
          <i data-lucide="mail" class="absolute right-4 top-3.5 text-slate-500 w-5 h-5"></i>
          <input type="email" name="email" required class="w-full bg-slate-900 border border-slate-700 rounded-xl pr-12 pl-4 py-3 text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all placeholder-slate-600" placeholder="أدخل بريدك الإلكتروني">
        </div>
      </div>

      <div>
        <label class="block text-slate-400 text-sm font-bold mb-2">كلمة المرور</label>
        <div class="relative">
          <i data-lucide="lock" class="absolute right-4 top-3.5 text-slate-500 w-5 h-5"></i>
          <input type="password" name="password" required class="w-full bg-slate-900 border border-slate-700 rounded-xl pr-12 pl-4 py-3 text-white focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all placeholder-slate-600" placeholder="أدخل كلمة المرور">
        </div>
      </div>

      <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black py-4 px-6 rounded-xl transition-all shadow-lg shadow-blue-500/30 transform hover:scale-[1.02] flex justify-center items-center gap-2 text-lg">
        دخول <i data-lucide="arrow-left" class="w-5 h-5"></i>
      </button>
    </form>

    <div class="mt-8 text-center text-slate-400">
      ليس لديك حساب؟ <a href="/register?redirect=<%= encodeURIComponent(locals.redirect || '') %>" class="text-blue-400 hover:text-blue-300 font-bold hover:underline transition-all">إنشاء حساب جديد</a>
    </div>
    
    <div class="mt-4 text-center">
      <a href="/" class="text-slate-500 hover:text-slate-300 text-sm transition-all flex items-center justify-center gap-1">
        <i data-lucide="home" class="w-4 h-4"></i> العودة للرئيسية
      </a>
    </div>

  </div>

  <script>
    lucide.createIcons();
  </script>
</body>
</html>
