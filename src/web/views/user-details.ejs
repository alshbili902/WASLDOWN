<%- include('partials/header') %>

<% const isSubActive = user.is_subscribed && user.subscription_end && new Date(user.subscription_end) > new Date(); %>

<div class="page-transition" id="user-details-page">
    <% if (typeof success_msg !== 'undefined' && success_msg) { %>
        <div class="card p-1 mb-8 border-emerald-500/30">
            <div class="bg-emerald-500/10 text-emerald-400 p-6 rounded-[22px] flex items-center gap-4 relative z-10">
                <i data-lucide="check-circle" class="w-6 h-6"></i>
                <span class="font-bold text-sm"><%= success_msg %></span>
            </div>
        </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="card p-1 mb-8 border-red-500/30">
            <div class="bg-red-500/10 text-red-400 p-6 rounded-[22px] flex items-center gap-4 relative z-10">
                <i data-lucide="alert-circle" class="w-6 h-6"></i>
                <span class="font-bold text-sm"><%= error %></span>
            </div>
        </div>
    <% } %>

    <div class="mb-10 flex items-center justify-between">
        <div class="flex items-center gap-6">
            <a href="/admin/users" class="w-12 h-12 bg-slate-800 hover:bg-blue-600 text-white rounded-2xl flex items-center justify-center transition-all border border-slate-700 shadow-lg">
                <i data-lucide="arrow-right" class="w-6 h-6"></i>
            </a>
            <div>
                <h1 class="text-4xl font-black text-white">تفاصيل المستخدم</h1>
                <p class="text-slate-400 font-medium">إدارة شاملة لبيانات الحساب واشتراكات VIP.</p>
            </div>
        </div>
        <% if(isSubActive) { %>
            <div class="bg-amber-500/10 text-amber-500 px-6 py-2 rounded-2xl border border-amber-500/20 font-black flex items-center gap-2">
                <i data-lucide="crown" class="w-5 h-5"></i>
                عضو VIP
            </div>
        <% } %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- معلومات المستخدم -->
        <div class="card p-1 section-download h-fit">
            <div class="bg-slate-900/95 rounded-[22px] p-8 relative z-10">
                <div class="flex flex-col items-center mb-8">
                    <div class="w-24 h-24 bg-blue-600 rounded-[32px] flex items-center justify-center text-white text-4xl font-black shadow-2xl border-4 border-slate-900 mb-6">
                        <%= (user.full_name || user.email || '?')[0].toUpperCase() %>
                    </div>
                    <h2 class="text-2xl font-black text-white mb-2"><%= user.full_name || 'مستخدم موقع' %></h2>
                    <p class="text-slate-500 font-medium text-sm mb-4"><%= user.email %></p>
                    <div class="bg-slate-800/50 px-4 py-2 rounded-xl border border-slate-700 text-[11px] font-bold text-blue-400 font-mono">
                        <%= user.telegram_username ? '@'+user.telegram_username : (user.telegram_id ? 'ID: ' + user.telegram_id : 'غير مربوط بتليجرام') %>
                    </div>
                </div>
                
                <div class="space-y-4">
                    <div class="flex justify-between items-center bg-slate-800/30 p-4 rounded-xl border border-slate-700/30">
                        <span class="text-slate-500 text-xs font-black uppercase">Telegram ID</span>
                        <span class="font-black text-white text-sm"><%= user.telegram_id || 'N/A' %></span>
                    </div>
                    <div class="flex justify-between items-center bg-slate-800/30 p-4 rounded-xl border border-slate-700/30">
                        <span class="text-slate-500 text-xs font-black uppercase">تاريخ التسجيل</span>
                        <span class="text-slate-300 text-xs font-bold" dir="ltr"><%= new Date(user.created_at).toLocaleDateString() %></span>
                    </div>
                    <div class="flex justify-between items-center bg-emerald-500/5 p-4 rounded-xl border border-emerald-500/10">
                        <span class="text-emerald-500/60 text-xs font-black uppercase">التحميلات</span>
                        <span class="text-emerald-400 font-black text-xl"><%= user.total_downloads || 0 %></span>
                    </div>
                </div>

                <div class="mt-8 pt-8 border-t border-slate-800">
                    <form action="/admin/users/<%= user.id %>/action" method="POST" onsubmit="return confirm('⚠️ تحذير: سيتم حذف المستخدم نهائياً من الموقع والبوت. هل أنت متأكد؟')">
                        <input type="hidden" name="action" value="delete">
                        <button type="submit" class="w-full bg-red-600/10 text-red-500 border border-red-500/30 hover:bg-red-600 hover:text-white py-3 rounded-xl font-black transition-all text-xs flex items-center justify-center gap-2">
                            <i data-lucide="trash-2" class="w-4 h-4"></i>
                            حذف المستخدم نهائياً
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- إدارة الاشتراك والتحكم -->
        <div class="lg:col-span-2 space-y-8">
            
            <!-- إدارة الاشتراك -->
            <div class="card p-1 section-vip">
                <div class="bg-slate-900/95 rounded-[22px] p-8 relative z-10">
                    <h3 class="text-2xl font-black text-white mb-8 flex items-center gap-3">
                        <i data-lucide="shield-check" class="w-6 h-6 text-amber-500"></i>
                        إدارة اشتراك VIP
                    </h3>
                    
                    <% if(isSubActive) { %>
                        <div class="bg-amber-500/10 border-2 border-amber-500/20 p-6 rounded-2xl mb-8 flex items-center justify-between">
                            <div>
                                <p class="text-amber-500 font-black text-lg mb-1">الاشتراك نشط حالياً ⭐</p>
                                <p class="text-slate-400 text-sm">تاريخ الانتهاء: <span dir="ltr" class="text-white font-mono font-bold"><%= new Date(user.subscription_end).toLocaleString() %></span></p>
                            </div>
                            <i data-lucide="star" class="w-10 h-10 text-amber-500/30 animate-pulse"></i>
                        </div>
                    <% } %>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
                        <form action="/admin/users/<%= user.id %>/action" method="POST">
                            <input type="hidden" name="action" value="activate">
                            <input type="hidden" name="amount" value="30">
                            <input type="hidden" name="unit" value="days">
                            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white py-4 rounded-xl font-black transition-all shadow-lg hover:scale-[1.02] active:scale-95 text-sm">
                                تفعيل 30 يوم
                            </button>
                        </form>
                        <form action="/admin/users/<%= user.id %>/action" method="POST">
                            <input type="hidden" name="action" value="activate">
                            <input type="hidden" name="amount" value="90">
                            <input type="hidden" name="unit" value="days">
                            <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 text-white py-4 rounded-xl font-black transition-all shadow-lg hover:scale-[1.02] active:scale-95 text-sm">
                                تفعيل 90 يوم
                            </button>
                        </form>
                        <form action="/admin/users/<%= user.id %>/action" method="POST">
                            <input type="hidden" name="action" value="activate">
                            <input type="hidden" name="amount" value="1">
                            <input type="hidden" name="unit" value="minutes">
                            <button type="submit" class="w-full bg-pink-600/10 text-pink-500 border border-pink-500/30 hover:bg-pink-600 hover:text-white py-4 rounded-xl font-black transition-all shadow-lg text-sm">
                                تجربة دقيقة واحدة
                            </button>
                        </form>
                    </div>

                    <form action="/admin/users/<%= user.id %>/action" method="POST" class="flex flex-col md:flex-row gap-4 p-6 bg-slate-800/50 rounded-2xl border border-slate-700/50">
                        <input type="hidden" name="action" value="activate">
                        <div class="flex-grow">
                            <label class="block text-[10px] text-slate-500 font-black uppercase mb-2 mr-2">تمديد مخصص</label>
                            <div class="flex gap-2">
                                <input type="number" name="amount" required min="1" placeholder="القيمة" class="w-1/2 bg-slate-950 border-2 border-slate-800 text-white px-5 py-3 rounded-xl focus:border-blue-500/50 outline-none font-bold">
                                <select name="unit" class="w-1/2 bg-slate-950 border-2 border-slate-800 text-white px-5 py-3 rounded-xl focus:border-blue-500/50 outline-none font-bold">
                                    <option value="days">أيام (Days)</option>
                                    <option value="minutes">دقائق (Minutes)</option>
                                </select>
                            </div>
                        </div>
                        <button type="submit" class="use-btn !m-0 !py-4 md:!px-10 self-end">تطبيق</button>
                    </form>

                    <% if(user.is_subscribed) { %>
                        <form action="/admin/users/<%= user.id %>/action" method="POST" class="mt-8 border-t border-slate-800 pt-8" onsubmit="return confirm('هل أنت متأكد من إلغاء اشتراك هذا المستخدم؟')">
                            <input type="hidden" name="action" value="deactivate">
                            <button type="submit" class="w-full bg-red-500/10 text-red-500 border border-red-500/20 hover:bg-red-600 hover:text-white py-3 rounded-xl font-black transition-all text-sm">
                                إلغاء الاشتراك فوراً
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>

            <!-- الرصيد التجريبي -->
            <div class="card p-1 section-features">
                <div class="bg-slate-900/95 rounded-[22px] p-8 relative z-10">
                    <h3 class="text-2xl font-black text-white mb-8 flex items-center gap-3">
                        <i data-lucide="gift" class="w-6 h-6 text-pink-500"></i>
                        الرصيد التجريبي (Free Trial)
                    </h3>

                    <div class="grid grid-cols-3 gap-6 mb-8">
                        <div class="bg-slate-800/40 p-4 rounded-2xl border border-slate-700/40 text-center">
                            <p class="text-slate-500 text-[10px] font-black mb-2 uppercase">الحد الكلي</p>
                            <p class="text-2xl font-black text-white"><%= user.trial_limit || 5 %></p>
                        </div>
                        <div class="bg-slate-800/40 p-4 rounded-2xl border border-slate-700/40 text-center">
                            <p class="text-slate-500 text-[10px] font-black mb-2 uppercase">المستخدم</p>
                            <p class="text-2xl font-black text-pink-500"><%= user.trial_used || 0 %></p>
                        </div>
                        <div class="bg-slate-800/40 p-4 rounded-2xl border border-slate-700/40 text-center">
                            <p class="text-slate-500 text-[10px] font-black mb-2 uppercase">المتبقي</p>
                            <p class="text-2xl font-black text-emerald-500"><%= Math.max(0, (user.trial_limit || 5) - (user.trial_used || 0)) %></p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-end">
                        <form action="/admin/users/<%= user.id %>/action" method="POST">
                            <input type="hidden" name="action" value="reset_trial">
                            <button type="submit" class="w-full bg-slate-800 hover:bg-slate-700 text-white py-4 rounded-xl font-black transition-all border border-slate-700 shadow-lg text-sm">
                                إعادة تصفير الاستخدام
                            </button>
                        </form>

                        <form action="/admin/users/<%= user.id %>/action" method="POST" class="flex flex-col">
                            <input type="hidden" name="action" value="update_limit">
                            <label class="block text-[10px] text-slate-500 font-black uppercase mb-2 mr-2">تعديل الحد المسموح</label>
                            <div class="flex gap-2">
                                <input type="number" name="trial_limit" value="<%= user.trial_limit || 5 %>" min="0" class="flex-grow bg-slate-950 border-2 border-slate-800 text-white px-5 py-3 rounded-xl focus:border-pink-500/50 outline-none font-bold">
                                <button type="submit" class="bg-pink-600 hover:bg-pink-500 text-white px-6 rounded-xl font-black transition-all shadow-lg text-xs">تحديث</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- إرسال رسالة خاصة -->
            <% if(user.telegram_id) { %>
            <div class="card p-1 section-download mt-8">
                <div class="bg-slate-900/95 rounded-[22px] p-8 relative z-10">
                    <h3 class="text-2xl font-black text-white mb-6 flex items-center gap-3">
                        <i data-lucide="message-circle" class="w-6 h-6 text-blue-500"></i>
                        إرسال رسالة مباشرة
                    </h3>
                    <form action="/admin/broadcast/send-single" method="POST" class="space-y-4">
                        <input type="hidden" name="telegram_id" value="<%= user.telegram_id %>">
                        <input type="hidden" name="profile_id" value="<%= user.id %>">
                        <textarea name="message" rows="4" required placeholder="اكتب رسالتك للمستخدم هنا..." class="w-full bg-slate-950 border-2 border-slate-800 text-white p-4 rounded-xl focus:border-blue-500/50 outline-none font-medium text-sm"></textarea>
                        <button type="submit" class="use-btn w-full !py-3 flex items-center justify-center gap-2">
                            <i data-lucide="send" class="w-4 h-4"></i>
                            إرسال للمستخدم الآن
                        </button>
                    </form>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const userDetailsPage = document.getElementById('user-details-page');
        setTimeout(() => userDetailsPage.classList.add('page-loaded'), 50);
        lucide.createIcons();
    });
</script>

<%- include('partials/footer') %>
