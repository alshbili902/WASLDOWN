  <!-- Scripts -->
  <script>
    lucide.createIcons();

    // Page Transition Logic
    document.addEventListener('DOMContentLoaded', () => {
      document.body.classList.add('dom-ready');
      const page = document.getElementById('page-transition');
      const glowBar = document.getElementById('glow-bar');

      if (page) {
        requestAnimationFrame(() => {
          page.classList.add('page-loaded');
        });
      }

      // Handle Internal Links
      document.querySelectorAll('a[href]').forEach((link) => {
        const href = link.getAttribute('href');

        // Check if internal
        const isInternal =
          href &&
          !href.startsWith('#') &&
          !href.startsWith('http') &&
          !href.startsWith('mailto:') &&
          !href.startsWith('tel:') &&
          !link.hasAttribute('target');

        if (!isInternal) return;

        link.addEventListener('click', (e) => {
          // If it's a middle click or Ctrl+Click, let the browser handle it
          if (e.button !== 0 || e.ctrlKey || e.shiftKey || e.metaKey) return;

          e.preventDefault();

          if (!page) {
            window.location.href = href;
            return;
          }

          // Start transition
          page.classList.remove('page-loaded');
          page.classList.add('page-leaving');
          
          if (glowBar) {
            glowBar.style.transform = 'translateX(0)';
          }

          setTimeout(() => {
            window.location.href = href;
          }, 450);
        });
      });
    });

    // Mobile Menu Logic - Fixed, Isolated & Animated
    const menuToggle = document.getElementById('menu-toggle');
    const menuClose = document.getElementById('menu-close');
    const mobileMenu = document.getElementById('mobileMenu');
    const menuLinks = mobileMenu.querySelectorAll('a');

    const openMenu = () => {
      mobileMenu.classList.remove('closing');
      mobileMenu.classList.add('open');
      document.body.classList.add('menu-open');
    };

    const closeMenu = () => {
      mobileMenu.classList.add('closing');
      
      // انتظار انتهاء الأنيميشن قبل الإخفاء التام
      setTimeout(() => {
        mobileMenu.classList.remove('open');
        mobileMenu.classList.remove('closing');
        document.body.classList.remove('menu-open');
      }, 450);
    };

    menuToggle.addEventListener('click', openMenu);
    menuClose.addEventListener('click', closeMenu);
    
    // إغلاق القائمة عند الضغط على أي رابط
    menuLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  </script>
