<%- include('partials/header') %>

<div class="page-transition" id="login-page">
    <div class="max-w-md mx-auto mt-20 card p-1 section-download">
        <div class="bg-slate-900/95 rounded-[22px] p-10 relative z-10">
            <div class="text-center mb-10">
                <div class="w-20 h-20 bg-blue-600/10 rounded-[28px] flex items-center justify-center mx-auto mb-6 border-2 border-blue-500/20 shadow-2xl">
                    <i data-lucide="shield-check" class="w-10 h-10 text-blue-500"></i>
                </div>
                <h1 class="text-3xl font-black text-white mb-2">تسجيل دخول المدير</h1>
                <p class="text-slate-500 font-medium text-sm uppercase tracking-widest">Admin Dashboard Access</p>
            </div>

            <% if (locals.error) { %>
                <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-4 rounded-xl mb-8 text-center text-xs font-black">
                    <i data-lucide="alert-circle" class="inline-block w-4 h-4 ml-1"></i>
                    <%= error %>
                </div>
            <% } %>

            <form action="/auth/login" method="POST" class="space-y-6">
                <div>
                    <label class="block text-[10px] text-slate-500 font-black uppercase mb-3 mr-2">اسم المستخدم / البريد</label>
                    <div class="relative group">
                        <i data-lucide="user" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-600 group-focus-within:text-blue-500 transition-colors"></i>
                        <input type="text" name="username" required autocomplete="off" placeholder="aa0556805220@gmail.com"
                               class="w-full bg-slate-950 border-2 border-slate-800 text-white pr-12 pl-4 py-4 rounded-xl focus:border-blue-500/50 outline-none transition-all font-bold text-sm placeholder:text-slate-800 dir-ltr">
                    </div>
                </div>
                
                <div>
                    <label class="block text-[10px] text-slate-500 font-black uppercase mb-3 mr-2">كلمة المرور</label>
                    <div class="relative group">
                        <i data-lucide="lock" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-600 group-focus-within:text-blue-500 transition-colors"></i>
                        <input type="password" name="password" required placeholder="••••••••"
                               class="w-full bg-slate-950 border-2 border-slate-800 text-white pr-12 pl-4 py-4 rounded-xl focus:border-blue-500/50 outline-none transition-all font-bold text-sm placeholder:text-slate-800 dir-ltr">
                    </div>
                </div>

                <button type="submit" class="use-btn w-full !py-4 shadow-blue-500/20 text-lg">
                    دخول الآمن
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-slate-800/50 text-center">
                <p class="text-slate-600 text-[10px] font-black uppercase tracking-tighter">
                    هذه المنطقة مخصصة للمديرين فقط. يتم تسجيل كافة محاولات الدخول.
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    .dir-ltr { direction: ltr; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const loginPage = document.getElementById('login-page');
        setTimeout(() => loginPage.classList.add('page-loaded'), 50);
        lucide.createIcons();
    });
</script>

<%- include('partials/footer') %>
