<%- include('partials/header') %>

<div class="page-transition" id="coupons-page">
    <div class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 card p-8 md:p-10 section-features">
        <div class="relative z-10">
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4">إدارة الكوبونات 🎟️</h1>
            <p class="text-slate-400 text-lg font-medium">أنشئ كوبونات الخصم، وزّع اشتراكات مجانية، وتحكم في حملاتك الترويجية.</p>
        </div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="card p-1 mb-8 border-red-500/30">
            <div class="bg-red-500/10 text-red-400 p-6 rounded-[22px] flex items-center gap-4 relative z-10">
                <i data-lucide="alert-circle" class="w-6 h-6"></i>
                <span class="font-bold"><%= error %></span>
            </div>
        </div>
    <% } %>

    <% if (typeof success !== 'undefined' && success) { %>
        <div class="card p-1 mb-8 border-emerald-500/30">
            <div class="bg-emerald-500/10 text-emerald-400 p-6 rounded-[22px] flex items-center gap-4 relative z-10">
                <i data-lucide="check-circle" class="w-6 h-6"></i>
                <span class="font-bold"><%= success %></span>
            </div>
        </div>
    <% } %>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- إنشاء كوبون جديد -->
        <div class="lg:col-span-1">
            <div class="card p-1 section-download sticky top-24">
                <div class="bg-slate-900/95 rounded-[22px] p-8 relative z-10">
                    <h2 class="text-2xl font-black text-white mb-8 flex items-center gap-3">
                        <i data-lucide="plus-square" class="w-6 h-6 text-blue-500"></i>
                        كوبون جديد
                    </h2>
                    <form action="/admin/coupons/create" method="POST" class="space-y-6">
                        <div>
                            <label class="block text-[10px] text-slate-500 font-black uppercase mb-2 mr-2">رمز الكوبون (Code)</label>
                            <input type="text" name="code" required class="w-full bg-slate-950 border-2 border-slate-800 rounded-xl px-5 py-3 text-white focus:border-blue-500/50 outline-none font-black uppercase placeholder:text-slate-700" placeholder="FREE2026">
                        </div>
                        <div>
                            <label class="block text-[10px] text-slate-500 font-black uppercase mb-2 mr-2">عدد أيام الاشتراك</label>
                            <input type="number" name="discount_percentage" required class="w-full bg-slate-950 border-2 border-slate-800 rounded-xl px-5 py-3 text-white focus:border-blue-500/50 outline-none font-bold placeholder:text-slate-700" placeholder="30">
                        </div>
                        <div>
                            <label class="block text-[10px] text-slate-500 font-black uppercase mb-2 mr-2">الحد الأقصى للاستخدام</label>
                            <input type="number" name="usage_limit" class="w-full bg-slate-950 border-2 border-slate-800 rounded-xl px-5 py-3 text-white focus:border-blue-500/50 outline-none font-bold placeholder:text-slate-700" placeholder="مثلاً: 50 (اتركه فارغاً لغير محدود)">
                        </div>
                        <div>
                            <label class="block text-[10px] text-slate-500 font-black uppercase mb-2 mr-2">تاريخ الانتهاء</label>
                            <input type="datetime-local" name="expires_at" class="w-full bg-slate-950 border-2 border-slate-800 rounded-xl px-5 py-3 text-white focus:border-blue-500/50 outline-none font-bold">
                        </div>
                        <button type="submit" class="use-btn w-full !py-4 shadow-blue-500/20">
                            إنشاء الكوبون الآن
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- قائمة الكوبونات -->
        <div class="lg:col-span-2">
            <div class="card p-1">
                <div class="bg-slate-900/95 rounded-[22px] overflow-hidden relative z-10">
                    <div class="p-8 border-b border-slate-800/50 flex justify-between items-center bg-slate-950/20">
                        <h2 class="text-2xl font-black text-white flex items-center gap-3">
                            <i data-lucide="ticket" class="w-6 h-6 text-indigo-500"></i>
                            الكوبونات النشطة
                        </h2>
                    </div>
                    
                    <% if (coupons && coupons.length > 0) { %>
                        <div class="overflow-x-auto">
                            <table class="w-full text-right">
                                <thead class="bg-slate-950/30 text-slate-500 text-xs uppercase tracking-widest">
                                    <tr>
                                        <th class="p-5 font-black">الرمز الترويجي</th>
                                        <th class="p-5 font-black text-center">الأيام</th>
                                        <th class="p-5 font-black text-center">الاستخدام</th>
                                        <th class="p-5 font-black">تاريخ الانتهاء</th>
                                        <th class="p-5 font-black text-center">إجراء</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-800/50">
                                    <% coupons.forEach(coupon => { %>
                                        <tr class="hover:bg-slate-800/30 transition-all group">
                                            <td class="p-5">
                                                <span class="bg-slate-800 border-2 border-slate-700 text-blue-400 font-black px-4 py-2 rounded-xl text-sm tracking-widest shadow-lg inline-block">
                                                    <%= coupon.code %>
                                                </span>
                                            </td>
                                            <td class="p-5 text-center font-black text-white">
                                                <span class="bg-blue-500/10 px-3 py-1 rounded-lg border border-blue-500/20"><%= coupon.discount_percentage %> يوم</span>
                                            </td>
                                            <td class="p-5 text-center">
                                                <div class="text-xs font-black text-slate-300"><%= coupon.used_count || 0 %> <span class="text-slate-600">/</span> <%= coupon.usage_limit || '∞' %></div>
                                                <div class="w-16 h-1 bg-slate-800 mx-auto mt-2 rounded-full overflow-hidden">
                                                    <div class="h-full bg-blue-500" style="width: <%= coupon.usage_limit ? Math.min(100, (coupon.used_count / coupon.usage_limit) * 100) : 0 %>%"></div>
                                                </div>
                                            </td>
                                            <td class="p-5 text-slate-500 text-[11px] font-medium">
                                                <%= coupon.expires_at ? new Date(coupon.expires_at).toLocaleString('ar-SA') : 'صلاحية مفتوحة' %>
                                            </td>
                                            <td class="p-5 text-center">
                                                <form action="/admin/coupons/delete/<%= coupon.code %>" method="POST" class="inline" onsubmit="return confirm('هل أنت متأكد من حذف هذا الكوبون؟');">
                                                    <button type="submit" class="bg-red-500/5 text-red-500 hover:bg-red-600 hover:text-white p-2.5 rounded-xl transition-all border border-red-500/10">
                                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="p-20 text-center text-slate-600">
                            <i data-lucide="ticket" class="w-16 h-16 mx-auto mb-6 opacity-20"></i>
                            <p class="text-lg font-black">لا توجد كوبونات نشطة حالياً</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const couponsPage = document.getElementById('coupons-page');
        setTimeout(() => couponsPage.classList.add('page-loaded'), 50);
        lucide.createIcons();
    });
</script>

<%- include('partials/footer') %>
