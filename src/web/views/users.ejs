<%- include('partials/header') %>

<div class="page-transition" id="users-page">
    <div class="mb-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-6 card p-8 md:p-10 section-pricing">
        <div class="relative z-10">
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4">إدارة المستخدمين 👥</h1>
            <p class="text-slate-400 text-lg font-medium">عرض وإدارة جميع حسابات البوت واشتراكاتهم والتحكم الكامل في صلاحياتهم.</p>
        </div>
        
        <form action="/admin/users" method="GET" class="relative z-10 w-full md:w-auto">
            <div class="relative group">
                <input type="text" name="search" value="<%= search %>" placeholder="ابحث بـ ID أو اسم أو بريد..." 
                       class="w-full md:w-80 bg-slate-950/50 border-2 border-slate-800 rounded-2xl px-6 py-4 text-white focus:border-blue-500/50 outline-none transition-all text-sm font-bold placeholder:text-slate-600">
                <button type="submit" class="absolute left-2 top-2 bottom-2 bg-blue-600 hover:bg-blue-500 text-white px-5 rounded-xl font-black transition-all text-xs">
                    بحث
                </button>
            </div>
            <% if(search) { %>
                <a href="/admin/users" class="absolute -bottom-6 right-0 text-[10px] text-slate-500 hover:text-blue-400 font-black uppercase tracking-widest">إلغاء البحث ✕</a>
            <% } %>
        </form>
    </div>

    <div class="card p-1">
        <div class="bg-slate-900/95 rounded-[22px] overflow-hidden relative z-10">
            <div class="overflow-x-auto">
                <table class="w-full text-right">
                    <thead class="bg-slate-950/30 text-slate-500 text-xs uppercase tracking-widest">
                        <tr>
                            <th class="p-5 font-black">ID / تليجرام</th>
                            <th class="p-5 font-black">المستخدم</th>
                            <th class="p-5 font-black">حالة الاشتراك</th>
                            <th class="p-5 font-black text-center">التحميلات</th>
                            <th class="p-5 font-black">تاريخ التسجيل</th>
                            <th class="p-5 font-black text-center">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-800/50">
                        <% users.forEach(user => { 
                            const isSubActive = user.is_subscribed && new Date(user.subscription_end) > new Date();
                        %>
                            <tr class="hover:bg-slate-800/30 transition-all group">
                                <td class="p-5 font-mono text-[11px] text-slate-500">
                                    <div class="text-slate-300 font-bold"><%= user.telegram_id || 'موقع فقط' %></div>
                                    <div class="opacity-30"><%= user.id.slice(0,12) %>...</div>
                                </td>
                                <td class="p-5">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 bg-slate-800 rounded-xl flex items-center justify-center text-emerald-400 font-bold border border-slate-700 group-hover:border-emerald-500/30 transition-all">
                                            <%= (user.full_name || user.email || '?')[0].toUpperCase() %>
                                        </div>
                                        <div>
                                            <div class="font-bold text-white text-sm"><%= user.full_name || 'مستخدم جديد' %></div>
                                            <div class="text-[11px] text-slate-500"><%= user.email %></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-5">
                                    <% if(isSubActive) { %>
                                        <span class="bg-amber-500/10 text-amber-500 px-3 py-1 rounded-lg text-[10px] font-black border border-amber-500/20 uppercase tracking-tighter">VIP ⭐</span>
                                        <div class="text-[9px] text-slate-600 mt-1" dir="ltr"><%= new Date(user.subscription_end).toLocaleDateString() %></div>
                                    <% } else { %>
                                        <span class="bg-slate-800 text-slate-500 px-3 py-1 rounded-lg text-[10px] font-black border border-slate-700 uppercase tracking-tighter">مجاني</span>
                                    <% } %>
                                </td>
                                <td class="p-5 text-center">
                                    <span class="text-sm font-black text-slate-300 bg-slate-800/50 px-3 py-1 rounded-md border border-slate-700/50"><%= user.total_downloads || 0 %></span>
                                </td>
                                <td class="p-5 text-slate-500 text-xs font-medium" dir="ltr"><%= new Date(user.created_at).toLocaleDateString('en-GB') %></td>
                                <td class="p-5">
                                    <div class="flex justify-center gap-2">
                                        <form action="/admin/users/<%= user.id %>/action" method="POST" class="inline">
                                            <input type="hidden" name="action" value="activate">
                                            <input type="hidden" name="days" value="30">
                                            <button type="submit" class="bg-emerald-500/10 text-emerald-500 hover:bg-emerald-600 hover:text-white px-3 py-1.5 rounded-lg text-[10px] font-black transition-all border border-emerald-500/10">
                                                +30 يوم
                                            </button>
                                        </form>
                                        <a href="/admin/users/<%= user.id %>" class="bg-slate-800 hover:bg-slate-700 text-white px-3 py-1.5 rounded-lg text-[10px] font-black transition-all border border-slate-700">
                                            إدارة
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                        <% if(users.length === 0) { %>
                            <tr><td colspan="6" class="p-16 text-center text-slate-500 font-bold">لا يوجد نتائج لهذا البحث.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const usersPage = document.getElementById('users-page');
        setTimeout(() => usersPage.classList.add('page-loaded'), 50);
        lucide.createIcons();
    });
</script>

<%- include('partials/footer') %>
