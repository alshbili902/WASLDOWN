<div class="space-y-6">
    <div class="bg-blue-500/5 border border-blue-500/10 p-4 rounded-2xl flex items-center gap-3">
        <i data-lucide="sparkles" class="w-5 h-5 text-blue-400"></i>
        <p class="text-sm text-slate-300">أدخل رابط مقال أو نص طويل ليقوم المحلل الذكي باستخراج الأفكار والهاشتاقات المناسبة.</p>
    </div>

    <form id="form-analyze" class="space-y-4">
        <textarea id="analyze-text" required placeholder="ضع النص هنا أو الرابط..." 
                  class="w-full bg-slate-900 border-2 border-slate-700 rounded-2xl px-6 py-4 text-white focus:border-blue-500 outline-none transition-all h-40 resize-none"></textarea>
        
        <button type="submit" id="analyze-btn" class="w-full bg-blue-600 hover:bg-blue-500 text-white py-4 rounded-2xl font-black text-xl flex items-center justify-center gap-3 transition-all">
            <i data-lucide="bar-chart-2" class="w-6 h-6"></i> تحليل المحتوى
        </button>
    </form>

    <div id="analyze-res" class="hidden p-6 bg-slate-900 rounded-2xl border border-slate-700 text-slate-300 whitespace-pre-line leading-relaxed max-h-60 overflow-y-auto">
        <!-- النتيجة -->
    </div>
</div>

<script>
  document.getElementById('form-analyze').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('analyze-btn');
    const resEl = document.getElementById('analyze-res');
    btn.disabled = true;
    btn.innerText = 'جاري التحليل...';

    try {
      const res = await fetch('/api/analyze-content', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text: document.getElementById('analyze-text').value })
      });
      const data = await res.json();
      if(data.error) throw new Error(data.error);
      resEl.innerText = data.result;
      resEl.classList.remove('hidden');
    } catch(err) {
      alert(err.message);
    } finally {
      btn.disabled = false;
      btn.innerText = 'تحليل المحتوى';
    }
  });
</script>
