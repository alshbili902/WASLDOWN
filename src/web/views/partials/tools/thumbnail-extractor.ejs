<div class="space-y-6">
    <div class="relative group">
        <input type="url" id="thumb-url" placeholder="ضع رابط الفيديو لاستخراج الغلاف..." 
               class="w-full bg-slate-900 border-2 border-slate-700 rounded-2xl px-6 py-4 text-white focus:border-blue-500 outline-none transition-all text-lg">
        <button id="extract-btn" class="absolute left-2 top-2 bottom-2 bg-blue-600 hover:bg-blue-500 text-white px-6 rounded-xl font-bold transition-all">
            استخراج
        </button>
    </div>

    <div id="thumb-loader" class="hidden text-center py-8">
        <div class="inline-block animate-spin w-8 h-8 border-4 border-blue-500 border-t-transparent rounded-full mb-4"></div>
        <p class="text-blue-400 font-medium">جاري جلب الصورة...</p>
    </div>

    <div id="thumb-res-container" class="hidden animate-in zoom-in duration-300">
        <div class="bg-slate-900 rounded-2xl border border-slate-700 overflow-hidden shadow-2xl">
            <img id="thumb-res-img" src="" alt="Thumbnail" class="w-full h-auto">
            <div class="p-6 flex flex-col md:flex-row gap-4 justify-between items-center">
                <span class="text-slate-400 text-sm">تم جلب الغلاف بأعلى جودة متاحة ✅</span>
                <a id="thumb-download-link" href="#" target="_blank" class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2 rounded-xl font-bold transition-all flex items-center gap-2">
                    <i data-lucide="download" class="w-4 h-4"></i> تحميل الصورة
                </a>
            </div>
        </div>
    </div>
</div>

<script>
  document.getElementById('extract-btn').addEventListener('click', async () => {
    const url = document.getElementById('thumb-url').value;
    if (!url) return alert('الرجاء وضع رابط أولاً');
    
    const loader = document.getElementById('thumb-loader');
    const resContainer = document.getElementById('thumb-res-container');
    const btn = document.getElementById('extract-btn');

    loader.classList.remove('hidden');
    resContainer.classList.add('hidden');
    btn.disabled = true;

    try {
      const res = await fetch('/api/media/inspect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ url })
      });
      const data = await res.json();
      if (data.error) throw new Error(data.error);

      document.getElementById('thumb-res-img').src = data.thumbnail;
      document.getElementById('thumb-download-link').href = data.thumbnail;
      resContainer.classList.remove('hidden');
    } catch (err) {
      alert(err.message);
    } finally {
      loader.classList.add('hidden');
      btn.disabled = false;
    }
  });
</script>
