<div class="space-y-6">
    <form action="/api/convert-image" method="POST" enctype="multipart/form-data" class="space-y-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="space-y-2">
                <label class="text-sm font-bold text-slate-400">اختر الصورة</label>
                <div class="relative h-40 border-2 border-dashed border-slate-700 rounded-2xl flex flex-col items-center justify-center bg-slate-900/30 hover:bg-slate-900/50 transition-all group">
                    <input type="file" name="image" accept="image/*" required class="absolute inset-0 opacity-0 cursor-pointer">
                    <i data-lucide="upload-cloud" class="w-10 h-10 text-slate-500 mb-2 group-hover:text-rose-400 transition-colors"></i>
                    <p class="text-slate-400 text-sm">اضغط هنا لرفع الصورة</p>
                </div>
            </div>

            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="text-sm font-bold text-slate-400">الصيغة المطلوبة</label>
                    <select name="format" class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 text-white outline-none focus:border-rose-500">
                        <option value="jpg">إلى JPG</option>
                        <option value="png">إلى PNG</option>
                        <option value="webp">إلى WEBP</option>
                        <option value="pdf">إلى PDF</option>
                    </select>
                </div>
                <button type="submit" class="w-full bg-rose-600 hover:bg-rose-500 text-white py-4 rounded-xl font-black text-lg flex items-center justify-center gap-3 transition-all shadow-xl shadow-rose-500/20">
                    <i data-lucide="repeat" class="w-6 h-6"></i> بدء التحويل
                </button>
            </div>
        </div>
    </form>
</div>
