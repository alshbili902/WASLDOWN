<% 
  const isVip = tool.vip;
  let sectionClass = 'section-download';
  if (isVip) {
    sectionClass = 'section-vip';
  } else if (tool.category === 'ذكاء اصطناعي') {
    sectionClass = 'section-features';
  } else if (tool.category === 'فيديو' || tool.category === 'صور') {
    sectionClass = 'section-pricing';
  }
%>
<a href="/tools/<%= tool.id %>" class="card tool-card group p-0 text-center <%= sectionClass %>">
    <div class="rounded-[24px] p-8 h-full flex flex-col items-center relative z-10 transition-all">
        <!-- Category Badge -->
        <span class="tool-category"><%= tool.category %></span>

        <% if (isVip) { %>
            <div class="absolute top-4 right-4 bg-amber-500/20 text-amber-500 text-[10px] font-black px-2 py-0.5 rounded-lg border border-amber-500/20 z-20 shadow-lg">VIP</div>
        <% } %>

        <!-- Icon -->
        <div class="w-16 h-16 bg-slate-950 rounded-2xl flex items-center justify-center text-blue-400 mb-6 border border-slate-700/50 group-hover:border-blue-500/50 group-hover:text-blue-300 transition-all shadow-xl group-hover:scale-110">
            <i data-lucide="<%= tool.icon %>" class="w-8 h-8"></i>
        </div>

        <!-- Title & Description -->
        <h3 class="text-xl font-black text-white mb-3 leading-tight group-hover:text-blue-400 transition-colors"><%= tool.name %></h3>
        <p class="text-[rgba(203,213,225,0.7)] text-sm line-clamp-2 mb-8 leading-relaxed font-medium max-w-[240px]"><%= tool.desc %></p>

        <!-- Use Button -->
        <div class="use-btn">
            <span>استخدام الأداة</span>
            <i data-lucide="zap" class="w-4 h-4"></i>
        </div>

        <!-- Secondary Download Indicator -->
        <span class="download-btn">
            <i data-lucide="download" class="w-3.5 h-3.5"></i>
            تحميل مباشر
        </span>
    </div>
</a>
