<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'لوحة التحكم' %> - وصل داونلودر</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;900&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    body {
      font-family: 'Tajawal', sans-serif;
      background-color: #0f172a; /* slate-900 */
      color: #f8fafc; /* slate-50 */
    }

    /* Premium Card System (Matching Landing Page Exactly) */
    @property --angle {
      syntax: '<angle>';
      initial-value: 0deg;
      inherits: false;
    }

    .section-download { --color1: #38bdf8; --color2: #6366f1; }
    .section-features { --color1: #a855f7; --color2: #ec4899; }
    .section-pricing { --color1: #22c55e; --color2: #4ade80; }
    .section-vip { --color1: #facc15; --color2: #f59e0b; }

    .card {
      position: relative;
      overflow: hidden;
      border-radius: 24px;
      background: rgba(15, 23, 42, 0.85);
      transition: all 0.3s ease;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
      backdrop-filter: blur(14px);
      --color1: #38bdf8;
      --color2: #6366f1;
    }

    .card::before {
      content: "";
      position: absolute;
      inset: -2px;
      border-radius: 24px;
      background: conic-gradient(
        from var(--angle),
        transparent 20%,
        var(--color1),
        var(--color2),
        var(--color1),
        transparent 80%
      );
      animation: spin 4s linear infinite, pulse 2.5s ease-in-out infinite;
      z-index: 0;
      filter: blur(6px);
      opacity: 0.7;
      transition: all 0.4s ease;
    }

    .card::after {
      content: "";
      position: absolute;
      inset: 2px;
      background: rgba(15, 23, 42, 0.95);
      border-radius: 22px;
      z-index: 1;
    }

    .card > * { position: relative; z-index: 2; }
    
    .card:hover {
      transform: translateY(-6px);
      box-shadow: 0 10px 30px rgba(99, 102, 241, 0.15);
    }

    .card:hover::before {
      animation: spin 2s linear infinite, pulse 2.5s ease-in-out infinite;
      opacity: 1;
      filter: blur(10px);
    }

    @keyframes spin {
      0% { --angle: 0deg; }
      100% { --angle: 360deg; }
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.5; filter: blur(4px); }
      50% { opacity: 1; filter: blur(8px); }
    }

    /* Categories & Badges */
    .tool-category {
      position: absolute;
      top: 16px;
      left: 16px;
      font-size: 11px;
      padding: 6px 14px;
      border-radius: 999px;
      background: rgba(59, 130, 246, 0.15);
      color: #60a5fa;
      border: 1px solid rgba(59, 130, 246, 0.35);
      backdrop-filter: blur(8px);
      font-weight: 900;
      letter-spacing: 0.5px;
      z-index: 30;
    }

    /* Action Buttons */
    .use-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin: 20px auto 0;
      padding: 12px 32px;
      font-size: 15px;
      font-weight: 800;
      border-radius: 14px;
      background: linear-gradient(135deg, #3b82f6, #6366f1);
      color: #ffffff;
      text-align: center;
      box-shadow: 0 10px 25px rgba(59, 130, 246, 0.35);
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .use-btn:hover {
      transform: translateY(-2px) scale(1.03);
      box-shadow: 0 14px 35px rgba(59, 130, 246, 0.45);
      filter: brightness(1.1);
    }

    .download-btn {
      position: absolute;
      bottom: 16px;
      left: 16px;
      font-size: 12px;
      font-weight: 700;
      color: rgba(255, 255, 255, 0.4);
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 6px;
      z-index: 20;
    }
    .tool-card:hover .download-btn {
      color: #60a5fa;
      opacity: 1;
    }

    /* Page Transitions */
    .page-transition {
      opacity: 0;
      transform: translateY(18px);
      filter: blur(4px);
      transition: opacity 0.5s ease, transform 0.5s cubic-bezier(.2,.9,.2,1), filter 0.5s ease;
    }
    .page-transition.page-loaded {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }

    /* Categories */
    .filter-btn.active {
      background: #2563eb !important;
      color: white !important;
      box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <% if (locals.user) { %>
    <nav class="bg-slate-800 border-b border-slate-700 p-4 sticky top-0 z-50 shadow-lg">
      <div class="container mx-auto flex justify-between items-center">
        <a href="/admin" class="text-2xl font-black text-blue-500 tracking-wider">لوحة الإدارة</a>
        <div class="flex gap-6 items-center">
          <a href="/admin" class="hover:text-blue-400 transition-colors <%= typeof path !== 'undefined' && (path === '/' || path === '/admin') ? 'text-blue-500 font-bold' : '' %>">الرئيسية</a>
          <a href="/admin/users" class="hover:text-blue-400 transition-colors <%= typeof path !== 'undefined' && path.startsWith('/users') ? 'text-blue-500 font-bold' : '' %>">المستخدمين</a>
          <a href="/admin/coupons" class="hover:text-blue-400 transition-colors <%= typeof path !== 'undefined' && path.startsWith('/admin/coupons') ? 'text-blue-500 font-bold' : '' %>">الكوبونات</a>
          <a href="/admin/broadcast" class="hover:text-blue-400 transition-colors <%= typeof path !== 'undefined' && path.startsWith('/admin/broadcast') ? 'text-blue-500 font-bold' : '' %>">إرسال جماعي</a>
          <a href="/auth/logout" class="bg-red-500/10 text-red-500 border border-red-500/50 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg transition-all text-sm font-bold">تسجيل الخروج</a>
        </div>
      </div>
    </nav>
  <% } else if (locals.userId) { %>
    <nav class="bg-slate-800 border-b border-slate-700 p-4 sticky top-0 z-50 shadow-lg">
      <div class="container mx-auto flex justify-between items-center">
        <a href="/" class="text-2xl font-black text-blue-500 tracking-wider flex items-center gap-2">
          <i data-lucide="download-cloud" class="w-6 h-6"></i> وصل داونلودر
        </a>
        <div class="flex gap-4 md:gap-6 items-center">
          <a href="/" class="hover:text-blue-400 transition-colors text-slate-300 font-bold">الرئيسية</a>
          <a href="/tools" class="hover:text-blue-400 transition-colors <%= typeof page !== 'undefined' && page === 'tools' ? 'text-blue-500 font-bold border-b-2 border-blue-500' : 'text-slate-300 font-bold' %>">الأدوات</a>
          <a href="/account" class="hover:text-blue-400 transition-colors <%= typeof page !== 'undefined' && page === 'account' ? 'text-blue-500 font-bold border-b-2 border-blue-500' : 'text-slate-300 font-bold' %>">حسابي</a>
          <a href="/logout" class="bg-red-500/10 text-red-400 border border-red-500/30 hover:bg-red-500 hover:text-white px-4 py-2 rounded-lg font-bold transition-all text-sm">خروج</a>
        </div>
      </div>
    </nav>
  <% } %>
  <main class="flex-grow container mx-auto p-4 md:p-6 lg:p-8">
